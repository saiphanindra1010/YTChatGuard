{
  "name": "safestream",
  "version": "3.0.0",
  "description": "SafeStream — AI-assisted YouTube live chat moderation",
  "main": "electron-main.js",
  "scripts": {
    "start": "node index.js",
    "desktop": "electron .",
    "dev": "nodemon index.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/tailwind.css --minify",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "youtube",
    "chat",
    "moderation",
    "ai",
    "gemini",
    "lmstudio",
    "openai",
    "live-streaming"
  ],
  "author": "phani",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.11.1",
    "axios": "^1.13.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^171.4.0",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "daisyui": "^4.12.24",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.safestream.app",
    "productName": "SafeStream",
    "files": [
      "index.js",
      "electron-main.js",
      "electron-preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
